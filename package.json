{
  "name": "apina",
  "version": "1.0.1",
  "description": "Apina API registry and MCP Server",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  },
  "lint-staged": {
    "*.py": [
      "ruff check --fix",
      "ruff format"
    ],
    "*.{json,yaml,yml}": [
      "prettier --write"
    ]
  }
}
